{
  "name": "@topos/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "trustedDependencies": [
    "esbuild",
    "@biomejs/biome"
  ],
  "exports": {
    "./routes": "./app/topos-web/routes.ts",
    "./nav": "./app/topos-web/nav.ts",
    "./entitlements": "./app/topos-web/entitlements.ts",
    "./auth-config": "./app/topos-web/auth-config.ts"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typegen": "react-router typegen",
    "gen:plane": "node scripts/gen-plane-types.mjs",
    "check:contract": "node scripts/gen-plane-types.mjs --check",
    "check:boundary": "node scripts/check-boundary.mjs",
    "check:tokens": "node scripts/check-design-tokens.mjs",
    "check:bundle": "node scripts/scan-bundle.mjs",
    "db:migrate": "node scripts/migrate.mjs",
    "check": "biome ci --error-on-warnings . && node scripts/check-design-tokens.mjs && node scripts/check-boundary.mjs && node scripts/gen-plane-types.mjs --check && react-router typegen && tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/martian-mono": "^5.2.7",
    "@pierre/diffs": "1.2.12",
    "@radix-ui/react-dialog": "^1.1.18",
    "@react-router/node": "8.2.0",
    "@react-router/serve": "8.2.0",
    "@sentry/react-router": "^10.65.0",
    "@shikijs/rehype": "^4.3.1",
    "@tanstack/react-query": "^5.101.2",
    "better-auth": "1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "lucide-react": "^1.23.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sanitize-html": "^2.17.5",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0",
    "unified": "^11.0.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@playwright/test": "1.61.1",
    "@react-router/dev": "8.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24",
    "@types/nodemailer": "^6.4.19",
    "@types/pg": "^8.15.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.0",
    "drizzle-kit": "0.31.10",
    "openapi-typescript": "7.13.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.0",
    "vite": "^7",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.9"
  }
}
