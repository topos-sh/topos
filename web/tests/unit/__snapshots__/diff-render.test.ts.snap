// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderFileDiffHTML > pins a small add+modify+delete render (sanitized output snapshot) 1`] = `"<pre data-diff data-diff-type="single" data-overflow="scroll" data-background data-indicators="bars" data-dehydrated><code data-code data-container-size data-unified><div data-gutter style="grid-row:span 5"><div data-line-type="context" data-column-number="1" data-line-index="0,0"><span data-line-number-content>1</span></div><div data-line-type="context" data-column-number="2" data-line-index="1,1"><span data-line-number-content>2</span></div><div data-line-type="change-deletion" data-column-number="3" data-line-index="2,2"><span data-line-number-content>3</span></div><div data-line-type="change-addition" data-column-number="3" data-line-index="3,2"><span data-line-number-content>3</span></div><div data-line-type="change-addition" data-column-number="4" data-line-index="4,3"><span data-line-number-content>4</span></div></div><div data-content style="grid-row:span 5"><div data-line="1" data-alt-line="1" data-line-type="context" data-line-index="0,0"><span style="color:#005CC5;font-weight:bold"># title</span></div><div data-line="2" data-alt-line="2" data-line-type="context" data-line-index="1,1"><span style="color:#24292E">keep this line</span></div><div data-line="3" data-line-type="change-deletion" data-line-index="2,2"><span data-diff-span><span style="color:#24292E">drop</span></span><span style="color:#24292E"> this line</span></div><div data-line="3" data-line-type="change-addition" data-line-index="3,2"><span data-diff-span><span style="color:#24292E">add</span></span><span style="color:#24292E"> this line</span></div><div data-line="4" data-line-type="change-addition" data-line-index="4,3"><span style="color:#24292E">and this one</span></div></div></code></pre>"`;
