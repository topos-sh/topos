# The web app's server-tier environment (see app/env.server.ts — parsed lazily, never at build).
# There is deliberately NO client-side env: the app ships zero VITE_-prefixed values.

# The web role's connection (broad SELECT on schema `plane`; full on schema `web`).
DATABASE_URL=postgresql://topos_web:web@localhost:5439/topos_dev

# Better Auth: the session secret (>= 32 chars) and this app's own public origin.
BETTER_AUTH_SECRET=change-me-to-a-long-random-string!!
BETTER_AUTH_URL=http://localhost:3000

# The vault, over the internal network, and the shared bearer for its internal session lane
# (the vault answers the whole lane with 404 until its side sets the same token).
PLANE_INTERNAL_URL=http://localhost:8790
PLANE_INTERNAL_TOKEN=dev-internal-token

# Optional: where /install reads the checksummed installer from (defaults to the repo's own).
# INSTALL_SH_PATH=../scripts/install.sh

APP_ENV=development
PLANE_PUBLIC_URL=http://localhost:8790 # while the plane is still directly exposed; unset once this app fronts the API
