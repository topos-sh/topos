{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Receipt",
  "description": "The ONE canonical receipt across all outcomes — the durable idempotency record (present even\non failures): one stable receipt per op, identical on retry.",
  "type": "object",
  "properties": {
    "bundle_digest": {
      "description": "The byte-exact consent hash (lowercase hex).",
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "command": {
      "type": "string"
    },
    "created_at": {
      "description": "RFC 3339 timestamp (the plane stamps it; never an ambient clock in `topos-core`).",
      "type": "string",
      "format": "date-time"
    },
    "current_generation": {
      "anyOf": [
        {
          "$ref": "#/$defs/Generation"
        },
        {
          "type": "null"
        }
      ]
    },
    "details": {
      "description": "Outcome-specific extra detail."
    },
    "expected_generation": {
      "anyOf": [
        {
          "$ref": "#/$defs/Generation"
        },
        {
          "type": "null"
        }
      ]
    },
    "op_id": {
      "description": "Client-minted UUIDv4, persisted before the first send.",
      "type": "string",
      "format": "uuid"
    },
    "outcome": {
      "$ref": "#/$defs/TerminalOutcome"
    },
    "schema_version": {
      "description": "Always `1` for this contract version (the schema pins it `const`).",
      "type": "integer",
      "format": "uint32",
      "const": 1,
      "minimum": 0
    },
    "skill_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "version_id": {
      "description": "The commit SHA-256 (lowercase hex).",
      "type": [
        "string",
        "null"
      ],
      "pattern": "^[0-9a-f]{64}$"
    },
    "workspace_id": {
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "op_id",
    "command",
    "outcome",
    "workspace_id",
    "created_at"
  ],
  "$defs": {
    "Generation": {
      "description": "The internal anti-replay counter `(epoch, seq)`. NEVER rendered to a user; the\nagent consumes `expected`/`current` on a CONFLICT.",
      "type": "object",
      "properties": {
        "epoch": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        },
        "seq": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0
        }
      },
      "required": [
        "epoch",
        "seq"
      ]
    },
    "TerminalOutcome": {
      "description": "The closed set of terminal outcomes the agent branches on. SCREAMING_SNAKE on the wire.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "OK",
            "CONFLICT",
            "DIVERGED",
            "DENIED",
            "UNAVAILABLE",
            "AMBIGUOUS_NAME",
            "RETRYABLE_FAILURE",
            "PERMANENT_FAILURE"
          ]
        },
        {
          "description": "A successfully-opened proposal — an explicit `--propose`, or a direct publish/revert the\nper-bundle protection DOWNGRADED to one (the receipt's `details.downgraded` says which).",
          "type": "string",
          "const": "NEEDS_REVIEW"
        }
      ]
    }
  }
}
