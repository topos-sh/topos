{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Receipt",
  "description": "The ONE canonical receipt across all 11 outcomes — the durable idempotency record (present even on failures): one stable receipt per op, identical on retry.",
  "type": "object",
  "required": [
    "command",
    "created_at",
    "op_id",
    "outcome",
    "schema_version",
    "workspace_id"
  ],
  "properties": {
    "bundle_digest": {
      "description": "The byte-exact consent hash.",
      "type": [
        "string",
        "null"
      ]
    },
    "command": {
      "type": "string"
    },
    "created_at": {
      "description": "RFC 3339 timestamp (the plane stamps it; never an ambient clock in `topos-core`).",
      "type": "string"
    },
    "current_generation": {
      "anyOf": [
        {
          "$ref": "#/definitions/Generation"
        },
        {
          "type": "null"
        }
      ]
    },
    "details": {
      "description": "Outcome-specific extra detail."
    },
    "expected_generation": {
      "anyOf": [
        {
          "$ref": "#/definitions/Generation"
        },
        {
          "type": "null"
        }
      ]
    },
    "key_id": {
      "description": "The signing key id that covered this op.",
      "type": [
        "string",
        "null"
      ]
    },
    "op_id": {
      "description": "Client-minted UUIDv4, persisted before the first send.",
      "type": "string"
    },
    "outcome": {
      "$ref": "#/definitions/TerminalOutcome"
    },
    "schema_version": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0.0
    },
    "skill_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "version_id": {
      "description": "The commit SHA-256.",
      "type": [
        "string",
        "null"
      ]
    },
    "workspace_id": {
      "type": "string"
    }
  },
  "definitions": {
    "Generation": {
      "description": "The internal anti-replay counter `(epoch, seq)`. NEVER rendered to a user; the agent consumes `expected`/`current` on a CONFLICT.",
      "type": "object",
      "required": [
        "epoch",
        "seq"
      ],
      "properties": {
        "epoch": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "seq": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        }
      }
    },
    "TerminalOutcome": {
      "description": "The closed set of terminal outcomes the agent branches on. SCREAMING_SNAKE on the wire.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "OK",
            "CONFLICT",
            "DIVERGED",
            "DENIED",
            "UNAVAILABLE",
            "AMBIGUOUS_NAME",
            "KEY_REPIN_REQUIRED",
            "RETRYABLE_FAILURE",
            "PERMANENT_FAILURE"
          ]
        },
        {
          "description": "A direct `publish` under `review-required`: refused, uploads/opens **nothing**, carries the `publish --propose` next-action.",
          "type": "string",
          "enum": [
            "APPROVAL_REQUIRED"
          ]
        },
        {
          "description": "Returned only for a successfully-opened proposal (an explicit `--propose`).",
          "type": "string",
          "enum": [
            "NEEDS_REVIEW"
          ]
        }
      ]
    }
  }
}
